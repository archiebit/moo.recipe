{
    "version": 4,
    "configurations":
    [
        {
            "name": "windows-dev",
            "includePath":
            [
                "${workspaceFolder}/include"
            ],
            "defines":
            [
                "DEBUG"
            ],

            "compilerPath": "clang++",
            "compilerArgs":
            [
                "-std=c++26"
            ],

            "intelliSenseMode": "windows-clang-x64",
            "cppStandard":      "c++23",
            "cStandard":        "c23",

            "browse":
            {
                "limitSymbolsToIncludedHeaders": true
            }
        },
        {
            "name": "windows-pro",
            "includePath":
            [
                "${workspaceFolder}/include"
            ],
            "defines": [ ],

            "compilerPath": "clang++",
            "compilerArgs":
            [
                "-std=c++26"
            ],

            "intelliSenseMode": "windows-clang-x64",
            "cppStandard":      "c++23",
            "cStandard":        "c23",

            "browse":
            {
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ]
}